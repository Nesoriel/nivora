# Nivora listens on loopback by default. Keep it private behind your product BFF.
NIVORA_ADDR=127.0.0.1:3100
NIVORA_SHARED_SECRET=replace-with-a-long-random-secret
NIVORA_TENANT_ID=lumio
NIVORA_PROVIDER_BASE_URL=http://127.0.0.1:3000
NIVORA_PROVIDER_SHARED_SECRET=replace-with-a-different-long-random-secret
NIVORA_REQUEST_TIMEOUT=90s
NIVORA_PROVIDER_TIMEOUT=10s
NIVORA_MAX_HISTORY_TURNS=12
NIVORA_MAX_QUESTION_BYTES=16384

# Volcengine Ark through the official Eino extension.
ARK_API_KEY=ark-xxxxxxxx
ARK_CHAT_MODEL=ep-xxxxxxxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

NIVORA_VERSION=dev
NIVORA_COMMIT=unknown
